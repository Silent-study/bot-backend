# ── Server ───────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins (leave blank for *)
ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://YOUR_EXTENSION_ID

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/silentstudy

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
# Get this from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── SMTP (Email) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Silent Study <your@gmail.com>"

# ── Discord Integration ───────────────────────────────────────
# Phase 1: OAuth2 Account Linking
# 1. Go to https://discord.com/developers/applications → your app → OAuth2
# 2. Add Redirect URI: https://yourdomain.com/api/auth/discord/callback
# 3. Copy Client ID and Client Secret here
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://yourdomain.com/api/auth/discord/callback

# Phase 2 & 3: Internal service communication
# Port the Discord bot's internal webhook listener runs on
DISCORD_BOT_PORT=4000
# Shared secret for backend → Discord bot webhook POSTs
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_WEBHOOK_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
# Shared key for Discord bot → backend internal API reads
# Can be the same value as INTERNAL_WEBHOOK_SECRET or a separate key
INTERNAL_API_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET
